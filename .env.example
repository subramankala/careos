# CareOS Lite - production pilot environment template
# Copy to .env and fill with real values before starting services.

# -----------------------------------------------------------------------------
# FastAPI runtime
# -----------------------------------------------------------------------------
CAREOS_LOG_LEVEL=INFO
CAREOS_DEFAULT_TIMEZONE=Asia/Kolkata
CAREOS_API_HOST=0.0.0.0
CAREOS_API_PORT=8115
CAREOS_API_WORKERS=1

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
CAREOS_DATABASE_URL=postgresql://careos_user:change_me@127.0.0.1:5432/careos_lite
CAREOS_USE_IN_MEMORY=false

# -----------------------------------------------------------------------------
# Twilio / WhatsApp ingress
# -----------------------------------------------------------------------------
CAREOS_VALIDATE_TWILIO_SIGNATURE=true
CAREOS_TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
CAREOS_PUBLIC_WEBHOOK_BASE_URL=https://careos.example.com
CAREOS_TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# -----------------------------------------------------------------------------
# Scheduler worker
# -----------------------------------------------------------------------------
CAREOS_SCHEDULER_POLL_SECONDS=30
# Optional allowlist for pilot bootstrapping. Leave blank to process all eligible rows
# once broader query support is enabled.
CAREOS_SCHEDULER_PATIENT_IDS=

# -----------------------------------------------------------------------------
# Conversation engine (must stay behind FastAPI control plane)
# -----------------------------------------------------------------------------
# Options: deterministic (default), openclaw
CAREOS_CONVERSATION_ENGINE=deterministic
# Optional when CAREOS_CONVERSATION_ENGINE=openclaw
CAREOS_OPENCLAW_BASE_URL=
CAREOS_OPENCLAW_TIMEOUT_SECONDS=15

# -----------------------------------------------------------------------------
# Voice / escalation placeholders for single-VM pilot
# -----------------------------------------------------------------------------
CAREOS_ENABLE_VOICE_ESCALATION=false
CAREOS_VOICE_CALLER_ID=
