[Unit]
Description=CareOS Lite MCP Server
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/kumarmankala/careos
EnvironmentFile=/home/kumarmankala/careos/.env
ExecStart=/home/kumarmankala/careos/.venv/bin/uvicorn careos.mcp_server:app --host 0.0.0.0 --port 8110
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
