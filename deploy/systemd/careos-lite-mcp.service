[Unit]
Description=CareOS Lite MCP Server
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/careos-lite
EnvironmentFile=/opt/careos-lite/.env
ExecStart=/opt/careos-lite/.venv/bin/uvicorn careos.mcp_server:app --host 0.0.0.0 --port 8110
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
