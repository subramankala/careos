[Unit]
Description=CareOS Lite API (FastAPI)
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/kumarmankala/careos
EnvironmentFile=/home/kumarmankala/careos/.env
ExecStart=/home/kumarmankala/careos/.venv/bin/uvicorn careos.main:app --host 0.0.0.0 --port 8115
Restart=always
RestartSec=3
User=ubuntu
Group=ubuntu

[Install]
WantedBy=multi-user.target
